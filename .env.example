# ── Project NOMAD secrets ───────────────────────────────────────────
# Copy to .env and fill in.  NEVER commit .env.
#   cp .env.example .env

# LiteLLM gateway master key — invent a long random string.
# Open WebUI and the crew authenticate to the gateway with this.
LITELLM_MASTER_KEY=sk-nomad-CHANGE-ME-to-a-long-random-string

# ── Cloud model providers ───────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Adobe Firefly (server-to-server OAuth) ──────────────────────────
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=
ADOBE_FIREFLY_SCOPES=openid,AdobeID,firefly_api,ff_apis
# Guardrail: Firefly calls cost credits. Leave false so the Writer agent
# routes image generation through the approval gate instead of spending.
NOMAD_FIREFLY_AUTOSPEND=false

# ── Image generation (v2 engine, gated `generate_image`) ────────────
# Ordered fallback chain. Default: local ComfyUI first (free, on the GPU), then
# OpenAI (gpt-image-1, uses OPENAI_API_KEY above), then Adobe Firefly (above).
NOMAD_IMAGE_PROVIDER=comfyui,openai,firefly
# Local ComfyUI HTTP API (runs on the host GPU; container reaches it via host.docker.internal).
COMFYUI_URL=http://host.docker.internal:8188
COMFYUI_MODEL=sdxl                    # sdxl (sd_xl_base_1.0) | flux (FLUX.1 schnell fp8) | flux2 (FLUX.2 [dev] — best quality/prompt adherence; ⚠ non-commercial license) | qwen (Qwen-Image — best text, Apache-2.0, commercial-safe)
# OpenAI Images backend (gpt-image-1 returns base64; dall-e-3 returns a URL).
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024

# ── Notion (mission control) ────────────────────────────────────────
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
# Filled in after running  python notion/setup_notion.py :
NOTION_DB_PROJECTS=
NOTION_DB_GOALS=
NOTION_DB_MILESTONES=
NOTION_DB_TASKS=
NOTION_DB_ACTIVITY=
NOTION_DB_APPROVALS=
NOTION_DB_KNOWLEDGE=

# ── GitHub ──────────────────────────────────────────────────────────
GITHUB_PAT=

# ── Postgres (memory/state; also backs n8n) ─────────────────────────
POSTGRES_USER=nomad
POSTGRES_PASSWORD=CHANGE-ME
POSTGRES_DB=nomad

# ── Approval gate: where the crew posts high-stakes actions ─────────
# An n8n webhook that creates an Approvals row and waits for your tap.
N8N_APPROVAL_WEBHOOK=http://n8n:5678/webhook/approval

# ── Voice: snappy on-device wake word (Picovoice Porcupine, optional) ──
# Free AccessKey from https://console.picovoice.ai (no card). Empty = the console
# falls back to the local Whisper listen-loop for the wake word.
PICOVOICE_ACCESS_KEY=
# Optional: swap the wake keyword (a .ppn in nomad-console/static/voice/) + its label.
# Built-in: jarvis_wasm.ppn ("Jarvis") or computer_wasm.ppn ("Computer").
PICOVOICE_KEYWORD=jarvis_wasm.ppn
PICOVOICE_LABEL=Jarvis
